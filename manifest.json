{
  "manifest_version": 3,
  "name": "Focus Mode - Joe",
  "version": "1.0",
  "description": "Block distracting sites",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.instagram.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}